DATABASE_URL=postgresql+psycopg://watchtower:watchtower@postgres:5432/watchtower
API_TOKEN=change-me
API_DEFAULT_ROLE=admin
# Optional: multiple named tokens, each with its own role, as "label:token:role" pairs
# separated by commas. When set, this takes priority over API_TOKEN/API_DEFAULT_ROLE.
# Example: API_TOKENS=alice:alice-secret-token:admin,bob:bob-secret-token:viewer
API_TOKENS=
CORS_ALLOWED_ORIGINS=http://localhost:3000
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=watchtower
MINIO_SECRET_KEY=watchtower-secret
MINIO_BUCKET=maintenance-artifacts
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_JOB_TIMEOUT_SECONDS=1800
# These must match the actual worker/scheduler hardening configured in docker-compose.yml
# and worker/Dockerfile — they are surfaced as-is on the operations hardening dashboard.
WORKER_RUN_AS_NON_ROOT=true
WORKER_READ_ONLY_FILESYSTEM=true
WORKER_NETWORK_RESTRICTED=false
WORKER_CPU_LIMIT=2
WORKER_MEMORY_LIMIT_MB=2048

